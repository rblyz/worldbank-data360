{
  "name": "worldbank-data360",
  "version": "0.1.6",
  "description": "TypeScript SDK for World Bank Data360 API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "worldbank": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "generate:types": "npx openapi-typescript https://raw.githubusercontent.com/worldbank/open-api-specs/refs/heads/main/Data360%20Open_API.json -o src/types/generated.ts",
    "example": "tsx examples/gdp-by-country.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "worldbank",
    "data360",
    "world-bank",
    "open-data",
    "sdk",
    "api",
    "api-client",
    "economics",
    "gdp",
    "indicators",
    "development-indicators",
    "wdi",
    "imf",
    "statistics",
    "csv",
    "cli"
  ],
  "author": "Ruslan Blyzniuk",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
